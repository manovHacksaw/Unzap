generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Project {
  id        String   @id @default(uuid())
  name      String
  files     String   // JSON string as SQLite doesn't support Json type directly in Prisma sometimes, but we'll try Json first
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String

  @@index([userId])
}

model Deployment {
  id              String   @id @default(uuid())
  contractAddress String
  classHash       String
  abi             String   // JSON string
  name            String?
  network         String
  createdAt       DateTime @default(now())
  userId          String

  @@index([userId])
}

model Transaction {
  id        String   @id @default(uuid())
  hash      String   @unique
  type      String
  status    String
  createdAt DateTime @default(now())
  userId    String

  @@index([userId])
}
