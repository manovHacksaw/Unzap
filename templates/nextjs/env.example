# ── Contract ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CONTRACT_ADDRESS={{ADDRESS}}
NEXT_PUBLIC_NETWORK={{NETWORK}}

# ── RPC Endpoint ─────────────────────────────────────────────────────────────
# Get a free Starknet RPC from https://dashboard.alchemy.com or https://dashboard.infura.io
# Without this, a public fallback is used (may have CORS issues in development).
NEXT_PUBLIC_RPC_URL=

# ── Privy (Embedded Wallets + Gasless) ───────────────────────────────────────
# Get these from https://dashboard.privy.io
# Set both to enable Privy social login (email, Google, Twitter, etc.)
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=

# ── AVNU Paymaster (Sponsor Gas Fees) ────────────────────────────────────────
# Get your API key from https://app.avnu.fi/en/paymaster
# When set, Privy write transactions are sponsored automatically via StarkZap.
# Your contract must be allowlisted in the AVNU dashboard first.
NEXT_PUBLIC_AVNU_API_KEY=
