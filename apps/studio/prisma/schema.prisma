generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id        String   @id @default(uuid())
  name      String
  files     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String

  @@index([userId])
}

model Deployment {
  id              String        @id @default(uuid())
  contractAddress String
  classHash       String
  abi             Json
  name            String?
  network         String
  createdAt       DateTime      @default(now())
  userId          String
  transactions    Transaction[]

  @@index([userId])
}

model Transaction {
  id           String      @id @default(uuid())
  hash         String      @unique
  type         String
  status       String
  createdAt    DateTime    @default(now())
  userId       String
  deployment   Deployment? @relation(fields: [deploymentId], references: [id])
  deploymentId String?

  @@index([userId])
  @@index([deploymentId])
}

model PrivyWallet {
  id        String   @id @default(uuid())
  userId    String   @unique
  walletId  String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}
